---
/**
 * 站标：策展人黄铜印章 —— 圆角方框 + 衬线 N + 黄铜句点。
 * variant="stamp" 时播放盖章入场动画（仅首页 Hero 使用）。
 * 颜色全部走令牌，深浅主题自适应。
 */
interface Props {
  variant?: "static" | "stamp";
  size?: number;
  withWordmark?: boolean;
  wordmark?: string;
}
const { variant = "static", size = 34, withWordmark = false, wordmark = "Nick Lian" } = Astro.props;
---

<span class:list={["logo-seal", variant === "stamp" && "logo-stamp"]}>
  <svg
    width={size}
    height={size}
    viewBox="0 0 64 64"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <rect x="5" y="5" width="54" height="54" rx="11" stroke="var(--brass)" stroke-width="2.5"></rect>
    <path d="M17 46 V18 H23.5 L36 38.5 V18 H42 V46 H35.5 L23 25.5 V46 Z" fill="var(--text)"></path>
    <circle class="logo-dot" cx="49.5" cy="42.5" r="4" fill="var(--brass)"></circle>
  </svg>
  {withWordmark && <span class="logo-wordmark">{wordmark}</span>}
</span>

<style>
  .logo-seal {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    line-height: 1;
  }
  .logo-wordmark {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 580;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  /* 盖章动画：自上而下压落 + 微旋转回正，黄铜句点随后点上 */
  @media (prefers-reduced-motion: no-preference) {
    .logo-stamp svg {
      animation: stamp-press var(--dur-enter) var(--ease-gallery) both;
      transform-origin: 50% 50%;
    }
    .logo-stamp .logo-dot {
      animation: dot-land 240ms var(--ease-gallery) 480ms both;
      transform-origin: 49.5px 42.5px;
    }
  }
  @keyframes stamp-press {
    0% {
      opacity: 0;
      transform: scale(1.45) rotate(-5deg);
    }
    62% {
      opacity: 1;
      transform: scale(0.97) rotate(0.5deg);
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }
  @keyframes dot-land {
    0% {
      opacity: 0;
      transform: scale(2.4);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
