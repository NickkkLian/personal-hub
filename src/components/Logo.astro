---
/**
 * 站标：圆形 NL 字标（参考图）——黄铜细圆环 + 衬线 NL 字母组合。
 * variant="stamp" 时播放盖章入场动画（仅首页 Hero 使用）。颜色走令牌，深浅自适应。
 */
interface Props {
  variant?: "static" | "stamp";
  size?: number;
  withWordmark?: boolean;
  wordmark?: string;
}
const { variant = "static", size = 34, withWordmark = false, wordmark = "Nick Lian" } = Astro.props;
---

<span class:list={["logo-seal", variant === "stamp" && "logo-stamp"]}>
  <svg
    width={size}
    height={size}
    viewBox="0 0 64 64"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <circle class="logo-ring" cx="32" cy="32" r="29.5" stroke="var(--brass)" stroke-width="2"></circle>
    <text
      class="logo-mono"
      x="32"
      y="41.5"
      text-anchor="middle"
      font-family="var(--font-display)"
      font-size="26"
      font-weight="560"
      letter-spacing="0.5"
      fill="var(--text)">NL</text
    >
  </svg>
  {withWordmark && <span class="logo-wordmark">{wordmark}</span>}
</span>

<style>
  .logo-seal {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    line-height: 1;
  }
  .logo-mono {
    font-variation-settings: "opsz" 40;
  }
  .logo-wordmark {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 580;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  /* 盖章动画：自上而下压落 + 微旋回正 */
  @media (prefers-reduced-motion: no-preference) {
    .logo-stamp svg {
      animation: stamp-press var(--dur-enter) var(--ease-gallery) both;
      transform-origin: 50% 50%;
    }
    .logo-stamp .logo-mono {
      animation: mono-in 260ms var(--ease-gallery) 360ms both;
    }
  }
  @keyframes stamp-press {
    0% {
      opacity: 0;
      transform: scale(1.4) rotate(-6deg);
    }
    62% {
      opacity: 1;
      transform: scale(0.97) rotate(0.5deg);
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }
  @keyframes mono-in {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
</style>
