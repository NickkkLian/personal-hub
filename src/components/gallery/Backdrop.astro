---
/**
 * 背景纵深系统（BLUEPRINT 附录 A · 方案 B+ 七平面 ★）：
 * ① 光场层（最远）= global.css body 的左上光池 + 顶亮下沉空气透视
 * ② 颜料雾 + 幽灵字（超大 Fraunces 展厅水印，允许出血）
 * ③ 建筑暗示层 = 远处下一间展厅门洞/拱廊的极淡剪影（≤5% 对比度）
 * ④ 画布墙 + 墙地分界（grain + global.css floor 色阶）
 * ⑤ 微尘层 = 光柱中 ≤6 颗缓慢漂浮颜料微粒
 * ⑦ 失焦前景（最近）= 页面边缘重度虚化颜料色形（古典雕塑位预留 → BACKLOG）
 * 七层滚动速率递增（最远最慢、最近最快），由 --sy 驱动 translate3d。
 * reduced-motion：停漂移/微尘/视差，纵深由色阶与遮挡静态成立。
 */
interface Props {
  room?: string;
  ghost?: string;
}
const { room, ghost } = Astro.props;
const roomVar = room ? `var(${room})` : "var(--brass)";
---

<div class="backdrop" aria-hidden="true" style={`--room-paint: ${roomVar}`}>
  {/* ③ 建筑暗示层：下一间展厅的拱门门洞（有色填充，看得见的"通往下一厅"开口） */}
  <svg
    class="arch"
    viewBox="0 0 600 620"
    preserveAspectRatio="xMidYMax meet"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <linearGradient id="arch-depth" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--paint-ink)" stop-opacity="0.9"></stop>
        <stop offset="70%" stop-color="var(--paint-ink)" stop-opacity="0.35"></stop>
        <stop offset="100%" stop-color="var(--paint-ink)" stop-opacity="0"></stop>
      </linearGradient>
    </defs>
    {/* 门内更深的空气（看进下一间暗厅） */}
    <path d="M150 620 V250 a150 150 0 0 1 300 0 V620 Z" fill="url(#arch-depth)"></path>
    {/* 门框发丝边 */}
    <path
      d="M150 620 V250 a150 150 0 0 1 300 0 V620"
      fill="none"
      stroke="var(--text)"
      stroke-width="1.5"
      stroke-opacity="0.5"></path>
  </svg>

  {/* ② 颜料雾 + 幽灵字 */}
  {
    ghost && (
      <div class="ghost font-display" data-par="ghost">
        {ghost}
      </div>
    )
  }
  <div class="mist mist-a" data-par="mist-a"></div>
  <div class="mist mist-b" data-par="mist-b"></div>
  <div class="mist mist-c" data-par="mist-c"></div>

  {/* ⑤ 微尘层 */}
  <div class="dust" data-par="dust">
    <i style="left:12%;top:22%;animation-delay:0s"></i>
    <i style="left:78%;top:14%;animation-delay:-6s"></i>
    <i style="left:62%;top:58%;animation-delay:-12s"></i>
    <i style="left:28%;top:74%;animation-delay:-18s"></i>
    <i style="left:88%;top:42%;animation-delay:-9s"></i>
    <i style="left:44%;top:36%;animation-delay:-15s"></i>
  </div>

  {/* ④ 画布纹理：内联 feTurbulence 油画布噪点 */}
  <svg class="grain" xmlns="http://www.w3.org/2000/svg">
    <filter id="canvas-grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch"
      ></feTurbulence>
      <feColorMatrix type="saturate" values="0"></feColorMatrix>
    </filter>
    <rect width="100%" height="100%" filter="url(#canvas-grain)"></rect>
  </svg>

  {/* ⑦ 失焦前景：页面边缘重度虚化颜料色形（最近、最快；古典雕塑位 → BACKLOG） */}
  <div class="fg-blur fg-left" data-par="fg-left"></div>
  <div class="fg-blur fg-right" data-par="fg-right"></div>
</div>

<style>
  .backdrop {
    position: fixed;
    inset: 0;
    z-index: 0; /* 在 body 背景色之上；内容层显式抬到 z-10（z-index:-1 会被压到背景色后导致整层不可见） */
    overflow: hidden;
    pointer-events: none;
    /* 景深：聚焦展品时由 body.is-focusing 整体轻微虚化（C 任务） */
    transition: filter var(--dur-move) var(--ease-gallery);
  }
  :global(body.is-focusing) .backdrop {
    filter: blur(3px);
  }

  /* ② 幽灵字：超大低对比展厅水印，越界出血 */
  .ghost {
    position: absolute;
    top: 3rem;
    right: -0.08em;
    font-size: clamp(7rem, 26vw, 24rem);
    font-weight: 600;
    line-height: 0.82;
    letter-spacing: -0.02em;
    color: var(--ghost-ink);
    white-space: nowrap;
    user-select: none;
    will-change: transform;
  }

  /* ③ 建筑暗示层：远厅拱门门洞，看得见的纵深开口 */
  .arch {
    position: absolute;
    left: 50%;
    bottom: -2%;
    width: min(88vw, 940px);
    height: auto;
    transform: translateX(-50%);
    opacity: 0.2;
  }
  :global([data-theme="dark"]) .arch {
    opacity: 0.4;
  }

  /* ② 颜料雾：参考图式大片柔和色场圆——多色相、低饱和、彼此叠压（墙上的色光） */
  .mist {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    will-change: transform;
  }
  .mist-a {
    width: 64vmax;
    height: 64vmax;
    top: -20vmax;
    left: -14vmax;
    background: radial-gradient(circle, var(--room-paint) 0%, transparent 62%);
    opacity: 0.22;
  }
  .mist-b {
    width: 52vmax;
    height: 52vmax;
    bottom: -18vmax;
    right: -12vmax;
    background: radial-gradient(circle, var(--brass) 0%, transparent 62%);
    opacity: 0.16;
  }
  .mist-c {
    width: 46vmax;
    height: 46vmax;
    top: 28vh;
    right: 14vw;
    background: radial-gradient(circle, var(--paint-rose) 0%, transparent 62%);
    opacity: 0.12;
  }
  :global([data-theme="dark"]) .mist-a {
    opacity: 0.28;
  }
  :global([data-theme="dark"]) .mist-b {
    opacity: 0.2;
  }
  :global([data-theme="dark"]) .mist-c {
    opacity: 0.16;
  }

  /* ⑤ 微尘层 */
  .dust {
    position: absolute;
    inset: 0;
    will-change: transform;
  }
  .dust i {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--room-paint);
    opacity: 0.3;
  }

  /* ⑦ 失焦前景：重度虚化颜料色形，贴边出血 */
  .fg-blur {
    position: absolute;
    width: 38vmax;
    height: 38vmax;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.26;
    will-change: transform;
  }
  .fg-left {
    bottom: -11vmax;
    left: -9vmax;
    background: radial-gradient(circle, var(--room-paint) 0%, transparent 60%);
  }
  .fg-right {
    top: -9vmax;
    right: -8vmax;
    background: radial-gradient(circle, var(--brass) 0%, transparent 60%);
    opacity: 0.2;
  }

  .grain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: var(--canvas-grain-opacity);
    mix-blend-mode: multiply;
  }
  :global([data-theme="dark"]) .grain {
    mix-blend-mode: screen;
  }

  /* ---- 七层视差：translate3d 由 --sy 驱动，速率递增 ---- */
  @media (prefers-reduced-motion: no-preference) {
    .arch {
      transform: translateX(-50%) translate3d(0, calc(var(--sy, 0) * -0.018px), 0);
    }
    .ghost {
      transform: translate3d(0, calc(var(--sy, 0) * -0.04px), 0);
    }
    .mist-a {
      animation: drift-a 46s var(--ease-gallery) infinite alternate;
    }
    .mist-b {
      animation: drift-b 58s var(--ease-gallery) infinite alternate;
    }
    .mist-c {
      animation: drift-a 64s var(--ease-gallery) infinite alternate-reverse;
    }
    .dust {
      transform: translate3d(0, calc(var(--sy, 0) * -0.09px), 0);
    }
    .dust i {
      animation: float 24s linear infinite;
    }
    .fg-left {
      transform: translate3d(0, calc(var(--sy, 0) * -0.2px), 0);
    }
    .fg-right {
      transform: translate3d(0, calc(var(--sy, 0) * -0.16px), 0);
    }
  }
  /* 移动端减量：隐藏微尘与失焦前景的视差负担 */
  @media (max-width: 640px) {
    .dust {
      display: none;
    }
  }

  @keyframes drift-a {
    to {
      transform: translate(6vmax, 4vmax);
    }
  }
  @keyframes drift-b {
    to {
      transform: translate(-5vmax, -6vmax);
    }
  }
  @keyframes float {
    0% {
      transform: translateY(0);
      opacity: 0;
    }
    12% {
      opacity: 0.18;
    }
    88% {
      opacity: 0.12;
    }
    100% {
      transform: translateY(-9vh) translateX(1.5vw);
      opacity: 0;
    }
  }
</style>

<script>
  // 视差驱动：rAF 节流写入 --sy（滚动位置），各层用 calc 差速位移。
  // 被动监听、reduced-motion 时完全不挂载。
  function wireParallax() {
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    if ((document.documentElement as HTMLElement).dataset.parallax) return;
    document.documentElement.dataset.parallax = "1";
    let ticking = false;
    const update = () => {
      document.documentElement.style.setProperty("--sy", String(window.scrollY));
      ticking = false;
    };
    addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true },
    );
    update();
  }
  wireParallax();
  document.addEventListener("astro:after-swap", () => {
    document.documentElement.style.setProperty("--sy", String(window.scrollY));
  });
</script>
