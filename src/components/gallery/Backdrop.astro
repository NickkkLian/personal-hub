---
/**
 * 背景纵深系统（BLUEPRINT 附录 A · 方案 B+ 七平面 ★）：
 * ① 光场层（最远）= global.css body 的左上光池 + 顶亮下沉空气透视
 * ② 颜料雾 + 幽灵字（超大 Fraunces 展厅水印，允许出血）
 * ③ 建筑暗示层 = 远处下一间展厅门洞/拱廊的极淡剪影（≤5% 对比度）
 * ④ 画布墙 + 墙地分界（grain + global.css floor 色阶）
 * ⑤ 微尘层 = 光柱中 ≤6 颗缓慢漂浮颜料微粒
 * ⑦ 失焦前景（最近）= 页面边缘重度虚化颜料色形（古典雕塑位预留 → BACKLOG）
 * 七层滚动速率递增（最远最慢、最近最快），由 --sy 驱动 translate3d。
 * reduced-motion：停漂移/微尘/视差，纵深由色阶与遮挡静态成立。
 */
interface Props {
  room?: string;
  ghost?: string;
}
import { floralArch } from "../../lib/floral-arch";
const { room, ghost } = Astro.props;
// 门厅（无 room）默认取雾蓝而非黄铜金——黄铜作氛围主色会让整页发黄（2026-07-21 站长反映）
const roomVar = room ? `var(${room})` : "var(--paint-mist)";
const floral = floralArch(); // 印象派花艺拱廊（确定性生成）
---

<div class="backdrop" aria-hidden="true" style={`--room-paint: ${roomVar}`}>
  {/* ③ 建筑暗示层：印象派花艺拱廊——细藤架结构 + 消失点柔光 + 从下往上一路生花（三层景深） */}
  <svg
    class="arch"
    viewBox="0 0 600 640"
    preserveAspectRatio="xMidYMax meet"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs set:html={floral.defs}></defs>
    <defs>
      {/* 拱内远空气（冷灰）+ 远端柔光 */}
      <radialGradient id="vault-depth" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--paint-ink)" stop-opacity="0.4"></stop>
        <stop offset="60%" stop-color="var(--paint-ink)" stop-opacity="0.12"></stop>
        <stop offset="100%" stop-color="var(--paint-ink)" stop-opacity="0"></stop>
      </radialGradient>
      <radialGradient id="vault-core" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--paint-canvas)" stop-opacity="0.95"></stop>
        <stop offset="100%" stop-color="var(--paint-canvas)" stop-opacity="0"></stop>
      </radialGradient>
    </defs>
    {/* 结构层：拱内空气 + 呼吸光核 + 细藤架轮廓（花攀附其上） */}
    <g class="arch-structure">
      <ellipse cx="300" cy="392" rx="126" ry="96" fill="url(#vault-depth)"></ellipse>
      <ellipse class="vault-light" cx="300" cy="418" rx="50" ry="36" fill="url(#vault-core)"></ellipse>
      <path
        d="M158 640 V262 a142 142 0 0 1 284 0 V640"
        fill="none"
        stroke="var(--text)"
        stroke-opacity="0.13"
        stroke-width="1"></path>
    </g>
    {/* 花艺三层景深：远（糊冷淡）→ 中（主花）→ 近（点睛清晰），从下往上生花 */}
    <g class="fa-back" set:html={floral.back}></g>
    <g class="fa-mid" set:html={floral.mid}></g>
    <g class="fa-front" set:html={floral.front}></g>
  </svg>

  {/* ② 颜料雾（重模糊氛围层） + 幽灵字 */}
  {
    ghost && (
      <div class="ghost font-display" data-par="ghost">
        {ghost}
      </div>
    )
  }
  <div class="haze haze-a" data-par="haze-a"></div>
  <div class="haze haze-b" data-par="haze-b"></div>

  {/* ② 柔和色场圆（可见的墙上色光圆，参考图）——与颜料雾叠加 */}
  <div class="field field-a" data-par="field-a"></div>
  <div class="field field-b" data-par="field-b"></div>
  <div class="field field-c" data-par="field-c"></div>

  {/* ⑤ 立体微粒层：空中浮粒，带高光与微投影＝立体；近大清、远小糊 */}
  <div class="dust" data-par="dust">
    <i style="left:12%;top:22%;--sz:7px;--bl:0px;animation-delay:0s"></i>
    <i style="left:78%;top:14%;--sz:3px;--bl:1.4px;animation-delay:-6s"></i>
    <i style="left:62%;top:58%;--sz:5px;--bl:0.4px;animation-delay:-12s"></i>
    <i style="left:28%;top:74%;--sz:8px;--bl:0px;animation-delay:-18s"></i>
    <i style="left:88%;top:42%;--sz:3px;--bl:1.6px;animation-delay:-9s"></i>
    <i style="left:44%;top:36%;--sz:4px;--bl:0.8px;animation-delay:-15s"></i>
    <i style="left:20%;top:50%;--sz:6px;--bl:0.2px;animation-delay:-3s"></i>
    <i style="left:70%;top:78%;--sz:3px;--bl:1.8px;animation-delay:-21s"></i>
    <i style="left:54%;top:18%;--sz:5px;--bl:0.5px;animation-delay:-11s"></i>
    <i style="left:36%;top:64%;--sz:2px;--bl:2px;animation-delay:-7s"></i>
  </div>

  {/* 亮色点光源：花间光斑，柔光晕 + 极慢呼吸微闪 */}
  <div class="lights" data-par="lights">
    <span style="left:31%;top:38%;--lz:14px;animation-delay:0s"></span>
    <span style="left:66%;top:30%;--lz:9px;animation-delay:-4s"></span>
    <span style="left:48%;top:60%;--lz:18px;animation-delay:-8s"></span>
    <span style="left:24%;top:66%;--lz:7px;animation-delay:-2s"></span>
    <span style="left:80%;top:56%;--lz:11px;animation-delay:-6s"></span>
    <span style="left:58%;top:80%;--lz:8px;animation-delay:-10s"></span>
  </div>

  {/* ④ 画布纹理：内联 feTurbulence 油画布噪点 */}
  <svg class="grain" xmlns="http://www.w3.org/2000/svg">
    <filter id="canvas-grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch"
      ></feTurbulence>
      <feColorMatrix type="saturate" values="0"></feColorMatrix>
    </filter>
    <rect width="100%" height="100%" filter="url(#canvas-grain)"></rect>
  </svg>

  {/* ⑦ 失焦前景：页面边缘重度虚化颜料色形（最近、最快；古典雕塑位 → BACKLOG） */}
  <div class="fg-blur fg-left" data-par="fg-left"></div>
  <div class="fg-blur fg-right" data-par="fg-right"></div>
</div>

<style>
  .backdrop {
    position: fixed;
    inset: 0;
    z-index: 0; /* 在 body 背景色之上；内容层显式抬到 z-10（z-index:-1 会被压到背景色后导致整层不可见） */
    overflow: hidden;
    pointer-events: none;
    /* 景深：聚焦展品时由 body.is-focusing 整体轻微虚化（C 任务） */
    transition: filter var(--dur-move) var(--ease-gallery);
  }
  :global(body.is-focusing) .backdrop {
    filter: blur(3px);
  }

  /* ② 幽灵字：展厅墙字水印（参考图——精致高对比衬线，含蓄不出血） */
  .ghost {
    position: absolute;
    top: 4.5rem;
    left: 0;
    right: 0;
    text-align: center;
    font-size: clamp(4rem, 13vw, 11rem);
    font-weight: 380;
    font-variation-settings: "opsz" 144;
    line-height: 0.9;
    letter-spacing: 0.06em;
    color: var(--ghost-ink);
    white-space: nowrap;
    user-select: none;
    will-change: transform;
  }

  /* ③ 建筑暗示层：远厅拱门门洞，看得见的纵深开口 */
  .arch {
    position: absolute;
    left: 50%;
    bottom: -2%;
    width: min(86vw, 920px);
    height: auto;
    transform: translateX(-50%);
    opacity: 0.82; /* 花艺是主角，需有存在感（仍是背景，靠柔渐变+景深不压内容） */
  }
  :global([data-theme="dark"]) .arch {
    opacity: 0.7;
  }
  /* 结构层（藤架/拱内空气）保持含蓄，让花攀在上面 */
  .arch-structure {
    opacity: 0.2;
  }
  /* 三层景深：远糊冷淡 → 中 → 近清晰点睛（大气透视） */
  .fa-back {
    filter: blur(3px);
    opacity: 0.6;
  }
  .fa-mid {
    filter: blur(1px);
    opacity: 0.85;
  }
  .fa-front {
    opacity: 0.98;
  }
  /* 消失点光核：极慢呼吸（远厅透光的微妙起伏） */
  .vault-light {
    opacity: 0.85;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* ② 颜料雾：重模糊的展厅空气（弥散氛围，无明显边界） */
  .haze {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    will-change: transform;
  }
  .haze-a {
    width: 70vmax;
    height: 70vmax;
    top: -24vmax;
    left: -18vmax;
    background: radial-gradient(circle, var(--room-paint) 0%, transparent 60%);
    opacity: 0.26;
  }
  .haze-b {
    width: 56vmax;
    height: 56vmax;
    bottom: -20vmax;
    right: -16vmax;
    /* 由黄铜金改雾蓝：与暖场平衡、去黄（莫奈冷暖并置） */
    background: radial-gradient(circle, var(--paint-mist) 0%, transparent 60%);
    opacity: 0.18;
  }

  /* ② 柔和色场圆：轻模糊、看得见边界的圆（参考图墙上色光） */
  .field {
    position: absolute;
    border-radius: 50%;
    filter: blur(34px);
    will-change: transform;
  }
  .field-a {
    width: 32vmax;
    height: 32vmax;
    top: 10vh;
    right: 7vw;
    /* 干玫瑰保留一抹暖意（莫奈的灰粉），但大幅降透明度不再压场 */
    background: radial-gradient(circle, var(--paint-rose) 0%, transparent 68%);
    opacity: 0.3;
  }
  .field-b {
    width: 24vmax;
    height: 24vmax;
    top: 42vh;
    left: 5vw;
    background: radial-gradient(circle, var(--room-paint) 0%, transparent 68%);
    opacity: 0.36;
  }
  .field-c {
    width: 28vmax;
    height: 28vmax;
    bottom: 6vh;
    right: 24vw;
    /* 由浅黄铜改鼠尾草绿：这层原是最大的"黄"源（0.32），换冷绿去黄 */
    background: radial-gradient(circle, var(--paint-sage) 0%, transparent 68%);
    opacity: 0.24;
  }
  :global([data-theme="dark"]) .haze-a {
    opacity: 0.3;
  }
  :global([data-theme="dark"]) .haze-b {
    opacity: 0.22;
  }
  :global([data-theme="dark"]) .field {
    opacity: 0.16;
  }

  /* ⑤ 微尘层 */
  .dust {
    position: absolute;
    inset: 0;
    will-change: transform;
  }
  .dust i {
    position: absolute;
    width: var(--sz, 4px);
    height: var(--sz, 4px);
    border-radius: 50%;
    /* 左上高光的颜料珠＝立体（呼应统一左上光源） */
    background: radial-gradient(circle at 34% 30%, #fff 0%, var(--room-paint) 62%, transparent 100%);
    filter: blur(var(--bl, 0));
    box-shadow: 0 1px 2px rgb(28 26 23 / 0.14); /* 微投影＝影子 */
    opacity: 0.4;
  }

  /* 亮色点光源：暖白柔光晕 */
  .lights {
    position: absolute;
    inset: 0;
    will-change: transform;
  }
  .lights span {
    position: absolute;
    width: var(--lz, 10px);
    height: var(--lz, 10px);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgb(255 253 244 / 0.95) 0%,
      rgb(255 244 214 / 0.5) 34%,
      transparent 70%
    );
    opacity: 0.7;
  }

  /* ⑦ 失焦前景：重度虚化颜料色形，贴边出血 */
  .fg-blur {
    position: absolute;
    width: 38vmax;
    height: 38vmax;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.2;
    will-change: transform;
  }
  .fg-left {
    bottom: -11vmax;
    left: -9vmax;
    background: radial-gradient(circle, var(--room-paint) 0%, transparent 60%);
  }
  .fg-right {
    top: -9vmax;
    right: -8vmax;
    /* 由黄铜金改雾蓝，去黄 */
    background: radial-gradient(circle, var(--paint-mist) 0%, transparent 60%);
    opacity: 0.14;
  }

  .grain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: var(--canvas-grain-opacity);
    mix-blend-mode: multiply;
  }
  :global([data-theme="dark"]) .grain {
    mix-blend-mode: screen;
  }

  /* ---- 七层视差：translate3d 由 --sy 驱动，速率递增 ---- */
  @media (prefers-reduced-motion: no-preference) {
    .arch {
      transform: translateX(-50%) translate3d(0, calc(var(--sy, 0) * -0.018px), 0);
    }
    .vault-light {
      animation: vault-breathe 14s var(--ease-gallery) infinite alternate;
    }
    .ghost {
      transform: translate3d(0, calc(var(--sy, 0) * -0.04px), 0);
    }
    .haze-a {
      animation: drift-a 46s var(--ease-gallery) infinite alternate;
    }
    .haze-b {
      animation: drift-b 58s var(--ease-gallery) infinite alternate;
    }
    .field-a {
      animation: drift-b 52s var(--ease-gallery) infinite alternate-reverse;
    }
    .field-b {
      animation: drift-a 60s var(--ease-gallery) infinite alternate;
    }
    .field-c {
      animation: drift-a 68s var(--ease-gallery) infinite alternate-reverse;
    }
    .dust {
      transform: translate3d(0, calc(var(--sy, 0) * -0.09px), 0);
    }
    .dust i {
      animation: float 24s linear infinite;
    }
    .lights {
      transform: translate3d(0, calc(var(--sy, 0) * -0.13px), 0);
    }
    .lights span {
      animation: twinkle 6.5s var(--ease-gallery) infinite alternate;
    }
    .fg-left {
      transform: translate3d(0, calc(var(--sy, 0) * -0.2px), 0);
    }
    .fg-right {
      transform: translate3d(0, calc(var(--sy, 0) * -0.16px), 0);
    }
  }
  /* 移动端减量：隐藏微尘与失焦前景的视差负担 */
  @media (max-width: 640px) {
    .dust,
    .lights {
      display: none;
    }
  }

  @keyframes twinkle {
    from {
      opacity: 0.28;
      transform: scale(0.72);
    }
    to {
      opacity: 0.85;
      transform: scale(1.16);
    }
  }
  @keyframes vault-breathe {
    from {
      opacity: 0.55;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1.08);
    }
  }
  @keyframes drift-a {
    to {
      transform: translate(6vmax, 4vmax);
    }
  }
  @keyframes drift-b {
    to {
      transform: translate(-5vmax, -6vmax);
    }
  }
  @keyframes float {
    0% {
      transform: translateY(0);
      opacity: 0;
    }
    12% {
      opacity: 0.18;
    }
    88% {
      opacity: 0.12;
    }
    100% {
      transform: translateY(-9vh) translateX(1.5vw);
      opacity: 0;
    }
  }
</style>

<script>
  // 视差驱动：rAF 节流写入 --sy（滚动位置），各层用 calc 差速位移。
  // 被动监听、reduced-motion 时完全不挂载。
  function wireParallax() {
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    if ((document.documentElement as HTMLElement).dataset.parallax) return;
    document.documentElement.dataset.parallax = "1";
    let ticking = false;
    const update = () => {
      document.documentElement.style.setProperty("--sy", String(window.scrollY));
      ticking = false;
    };
    addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true },
    );
    update();
  }
  wireParallax();
  document.addEventListener("astro:after-swap", () => {
    document.documentElement.style.setProperty("--sy", String(window.scrollY));
  });
</script>
