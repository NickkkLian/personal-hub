---
/**
 * 装裱组件（BLUEPRINT 5.1 / 附录 A 装裱规范）：
 * - canvas（默认）：无框画布——0.5px 极淡描边收口 + 柔影承重
 * - float：发丝浮框——1px 墨色细框 + 10px 可见留缝（墙面透出），仅 featured 展品用
 * 任何 ≥2px 深色粗边框全站禁用。统一左上定向光；
 * interactive 时：抬升 + hover 射灯（指针跟踪径向提亮）+ 触发背景景深虚化（DOF）。
 */
interface Props {
  variant?: "canvas" | "float";
  /** 是否启用 hover 射灯/抬升/景深（列表卡用，静态展示关闭） */
  interactive?: boolean;
  class?: string;
}
const { variant = "canvas", interactive = false, class: className } = Astro.props;
const spot = interactive ? "exhibit-spot" : undefined;
---

{
  variant === "float" ? (
    <div
      class:list={["exhibit-float", interactive && "exhibit-hover", className]}
      data-dof={interactive ? "" : undefined}
    >
      <div class:list={["exhibit-float-inner", spot]}>
        <slot />
      </div>
    </div>
  ) : (
    <div class:list={["exhibit-canvas", interactive && "exhibit-hover", spot, className]}>
      <slot />
    </div>
  )
}

<style>
  .exhibit-canvas {
    position: relative;
    background: var(--surface);
    border: 0.5px solid color-mix(in oklab, var(--text) 10%, transparent);
    border-radius: var(--radius-frame);
    box-shadow: var(--shadow-exhibit);
  }

  .exhibit-float {
    border: 1px solid var(--line-frame);
    border-radius: var(--radius-frame);
    padding: 10px; /* 留缝：墙面从缝中透出 */
    box-shadow: var(--shadow-exhibit);
    background: transparent;
  }
  .exhibit-float-inner {
    position: relative;
    background: var(--surface);
    border: 0.5px solid color-mix(in oklab, var(--text) 8%, transparent);
    border-radius: 2px;
    height: 100%;
  }

  /* hover 射灯：指针处局部径向提亮（展厅射灯亮起） */
  .exhibit-spot::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      circle at var(--mx, 50%) var(--my, 0%),
      color-mix(in oklab, var(--brass-hi) 22%, transparent) 0%,
      transparent 42%
    );
    transition: opacity var(--dur-move) var(--ease-gallery);
    z-index: 1;
  }
  .exhibit-spot:hover::after {
    opacity: 1;
  }
  /* 射灯下内容仍在最上 */
  .exhibit-spot > :global(*) {
    position: relative;
    z-index: 2;
  }

  @media (prefers-reduced-motion: no-preference) {
    .exhibit-hover {
      transition:
        transform var(--dur-move) var(--ease-gallery),
        box-shadow var(--dur-move) var(--ease-gallery);
    }
  }
  .exhibit-hover:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lift);
  }
</style>

<script>
  // 射灯指针跟踪 + 景深：委托监听，View Transitions 后依然有效。
  function wireSpotlight() {
    if ((document.body as HTMLElement).dataset.spotwired) return;
    document.body.dataset.spotwired = "1";
    document.addEventListener(
      "pointermove",
      (e) => {
        const spot = (e.target as Element).closest<HTMLElement>(".exhibit-spot");
        if (!spot) return;
        const r = spot.getBoundingClientRect();
        spot.style.setProperty("--mx", `${((e.clientX - r.left) / r.width) * 100}%`);
        spot.style.setProperty("--my", `${((e.clientY - r.top) / r.height) * 100}%`);
      },
      { passive: true },
    );
    // 景深：仅在聚焦签名级浮框展品（featured / 沉浸）时背景虚化引导视线，
    // 缩略图卡不触发——避免全屏 blur 在密集网格上反复重栅格化。
    document.addEventListener("pointerover", (e) => {
      if ((e.target as Element).closest("[data-dof]")) document.body.classList.add("is-focusing");
    });
    document.addEventListener("pointerout", (e) => {
      const to = e.relatedTarget as Element | null;
      if (!to || !to.closest("[data-dof]")) document.body.classList.remove("is-focusing");
    });
  }
  wireSpotlight();
</script>
