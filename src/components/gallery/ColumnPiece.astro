---
/**
 * 古典石柱（BLUEPRINT 古典馆藏层的 SVG 实现）：精致凹槽柱身 + 爱奥尼柱头 + 阶式柱础，
 * 石膏/大理石色但压低饱和、与画廊暖调统一；作为**背景元素**置于角落/边缘，绝不与主内容并列。
 * 仅随滚动轻微前景视差。
 */
interface Props {
  width?: number;
  class?: string;
}
const { width = 96, class: className } = Astro.props;
// 20 道凹槽（柱身 26→134）
const flutes = Array.from({ length: 19 }, (_, i) => 30 + i * 5.6);
---

<svg
  class:list={["column-piece", className]}
  viewBox="0 0 160 900"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  preserveAspectRatio="xMidYMin meet"
  style={`width: ${width}px`}
>
  <defs>
    <!-- 石膏横向受光：左亮右暗（与全站左上光一致） -->
    <linearGradient id="stone" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#e7e0d2"></stop>
      <stop offset="34%" stop-color="#d6cdbc"></stop>
      <stop offset="72%" stop-color="#b9af9c"></stop>
      <stop offset="100%" stop-color="#a39884"></stop>
    </linearGradient>
    <linearGradient id="stone-cap" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#ece5d8"></stop>
      <stop offset="50%" stop-color="#d2c8b6"></stop>
      <stop offset="100%" stop-color="#a89d89"></stop>
    </linearGradient>
  </defs>

  {/* 爱奥尼柱头：顶板 + 双涡卷 + 颈线 */}
  <rect x="4" y="0" width="152" height="16" rx="1.5" fill="url(#stone-cap)"></rect>
  <rect x="10" y="16" width="140" height="12" fill="url(#stone-cap)"></rect>
  <path
    d="M44 28 a18 18 0 1 0 0.1 0 M40 46 a8 8 0 1 1 0.1 0"
    stroke="#8f846f"
    stroke-width="2.4"
    fill="none"
    opacity="0.7"></path>
  <path
    d="M116 28 a18 18 0 1 0 0.1 0 M112 46 a8 8 0 1 1 0.1 0"
    stroke="#8f846f"
    stroke-width="2.4"
    fill="none"
    opacity="0.55"></path>
  <rect x="22" y="50" width="116" height="6" fill="url(#stone-cap)"></rect>
  <rect x="26" y="56" width="108" height="10" rx="1" fill="url(#stone)"></rect>

  {/* 柱身（轻微 entasis：上下略收） */}
  <path d="M30 66 q-4 400 0 786 h100 q4 -386 0 -786 Z" fill="url(#stone)"></path>
  {
    flutes.map((x) => (
      <line x1={x} y1="72" x2={x} y2="846" stroke="#8f846f" stroke-width="1.1" opacity="0.28" />
    ))
  }
  {/* 高光凹槽（左侧受光） */}
  <line x1="36" y1="72" x2="36" y2="846" stroke="#f3eee5" stroke-width="1.4" opacity="0.5"></line>
  <line x1="44" y1="72" x2="44" y2="846" stroke="#f3eee5" stroke-width="1.2" opacity="0.32"></line>

  {/* 柱础：环线 + 阶板 */}
  <rect x="26" y="852" width="108" height="10" rx="1" fill="url(#stone)"></rect>
  <rect x="18" y="862" width="124" height="14" rx="1.5" fill="url(#stone-cap)"></rect>
  <rect x="6" y="876" width="148" height="20" rx="2" fill="url(#stone)"></rect>
</svg>

<style>
  .column-piece {
    display: block;
    height: auto;
    /* 与画廊暖调统一：略降饱和 + 轻柔影 */
    filter: saturate(0.8) drop-shadow(3px 6px 10px rgba(28, 26, 23, 0.12));
  }
  :global([data-theme="dark"]) .column-piece {
    filter: saturate(0.7) brightness(0.82) drop-shadow(3px 6px 12px rgba(0, 0, 0, 0.4));
  }
</style>
