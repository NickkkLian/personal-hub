---
/**
 * 展厅装饰横幅：复用生成式流场纹理，但用 mix-blend 收进展厅主题色系（同色相、仅明度起伏），
 * 与普通封面区分；展厅副标题（首页大标题同款 Playfair，不斜不粗）压在左下角。
 * 高度较矮的一条横幅（占满宽度）。
 */
import Cover from "./Cover.astro";

interface Props {
  module: string;
  seed: string;
  caption?: string;
}
const { module, seed, caption } = Astro.props;
---

<div class="room-band enter-rise is-in">
  <div class="room-band-art" aria-hidden="true">
    <Cover id={seed} module={module} w={1200} h={220} />
  </div>
  <div class="room-band-tint" aria-hidden="true"></div>
  <div class="room-band-scrim" aria-hidden="true"></div>
  {caption && <p class="room-band-caption">{caption}</p>}
</div>

<style>
  .room-band {
    position: relative;
    margin: clamp(1.6rem, 4vh, 2.6rem) 0;
    border-radius: var(--radius-frame);
    overflow: hidden;
    box-shadow: var(--shadow-exhibit);
    border: 0.5px solid color-mix(in oklab, var(--text) 9%, transparent);
    background: var(--room);
  }
  .room-band-art {
    height: clamp(82px, 11vh, 118px);
  }
  .room-band-art :global(.cover-art),
  .room-band-art :global(svg) {
    height: 100%;
    width: 100%;
  }
  /* 把流场纹理收进展厅主题色系：取主题色相 + 纹理明度 */
  .room-band-tint {
    position: absolute;
    inset: 0;
    background: var(--room);
    mix-blend-mode: color;
  }
  /* 左下暗角：保证题字可读 */
  .room-band-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top right,
      color-mix(in oklab, var(--room) 45%, rgba(14, 12, 10, 0.62)) 0%,
      transparent 58%
    );
  }
  .room-band-caption {
    position: absolute;
    left: clamp(1rem, 3vw, 1.8rem);
    bottom: clamp(0.6rem, 1.8vw, 1rem);
    margin: 0;
    max-width: 72%;
    font-family: "Playfair Display Variable", Georgia, serif;
    font-weight: 400;
    font-style: normal;
    font-size: clamp(1rem, 1.9vw, 1.4rem);
    line-height: 1.2;
    color: #f3eee5;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
  }
</style>
