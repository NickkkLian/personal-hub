---
import { t, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<button
  type="button"
  data-theme-toggle
  class="grid h-9 w-9 place-items-center rounded-sm border border-hair text-muted transition-colors hover:text-text"
  aria-label={t(locale, "a11y.themeToggle")}
>
  <!-- 日场：太阳 -->
  <svg class="icon-sun" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
    <circle cx="7.5" cy="7.5" r="3" stroke="currentColor" stroke-width="1.3"></circle>
    <path
      d="M7.5 0.5v2M7.5 12.5v2M0.5 7.5h2M12.5 7.5h2M2.55 2.55l1.4 1.4M11.05 11.05l1.4 1.4M2.55 12.45l1.4-1.4M11.05 3.95l1.4-1.4"
      stroke="currentColor"
      stroke-width="1.3"
      stroke-linecap="round"></path>
  </svg>
  <!-- 夜场：月亮 -->
  <svg class="icon-moon" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
    <path
      d="M13 9.5A6 6 0 1 1 5.5 2 4.8 4.8 0 0 0 13 9.5Z"
      stroke="currentColor"
      stroke-width="1.3"
      stroke-linejoin="round"></path>
  </svg>
</button>

<style>
  [data-theme-toggle] .icon-moon {
    display: none;
  }
  :global([data-theme="dark"]) [data-theme-toggle] .icon-sun {
    display: none;
  }
  :global([data-theme="dark"]) [data-theme-toggle] .icon-moon {
    display: block;
  }
</style>

<script>
  document.addEventListener("click", (e) => {
    if (!(e.target as Element).closest("[data-theme-toggle]")) return;
    const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("hub-theme", next);
  });
</script>
