---
/**
 * My Music（P3）：录音室——黑胶作品卡（唱片从封套探出，hover 滑出更多），
 * 内嵌播放器：播放时唱片旋转 + Web Audio 音波可视化。
 * 音频来源三态：extra.audio（真实试听文件，路径已预留）→ extra.demo（内置合成音色演示）→ 无（仅平台外链）。
 * reduced-motion：唱片不转、可视化静止；移动端单列。
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cover from "../../components/gallery/Cover.astro";
import FeatureCard from "../../components/gallery/FeatureCard.astro";
import ExhibitLabel from "../../components/gallery/ExhibitLabel.astro";
import { t, pickLang, type Locale } from "../../i18n";
import { MODULE_REGISTRY } from "../../config/site";
import { entries, pickFeatured } from "../../lib/data";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const meta = MODULE_REGISTRY["my-music"];
const allTracks = entries("my-music");
const featured = pickFeatured("my-music", allTracks);
const tracks = allTracks.filter((e) => e !== featured);
const title = t(locale, "module.my-music.title");
---

<BaseLayout
  locale={locale}
  title={title}
  description={t(locale, "module.my-music.intro")}
  path={`/${meta.slug}`}
  room={meta.room}
  ghost={t(locale, "module.my-music.ghost")}
>
  <article style={`--room: var(${meta.room})`}>
    <header class="module-head enter-rise is-in">
      <p class="meta-mono room-tag">
        {t(locale, "home.roomLabel")}
        {meta.roomNo} — {t(locale, "myMusic.studioTag")}
      </p>
      <h1 class="module-title">{title}</h1>
      <p class="module-intro">{t(locale, "module.my-music.intro")}</p>
    </header>

    {
      featured && (
        <FeatureCard
          locale={locale}
          entry={featured}
          module="my-music"
          moduleLabel="MY MUSIC"
          label={t(locale, "common.featured")}
          href={featured.links[0]?.url ?? null}
          meta={[featured.extra.year, featured.tags[0]].filter(Boolean).join(" · ")}
        />
      )
    }

    <hr class="hairline my-10" />

    <ul class="grid grid-cols-1 gap-10 md:grid-cols-2" role="list">
      {
        tracks.map((e, i) => {
          const audio = typeof e.extra.audio === "string" ? e.extra.audio : null;
          const playable = Boolean(audio || e.extra.demo);
          return (
            <li class="enter-rise" style={`transition-delay:${Math.min(i * 80, 320)}ms`}>
              <div class="record" data-track={e.id} data-audio={audio} data-demo={e.extra.demo ? "1" : null}>
                <div class="record-stage">
                  {/* 黑胶：从封套探出一截，播放时旋转 */}
                  <div class="vinyl" aria-hidden="true">
                    <div class="vinyl-grooves" />
                    <div class="vinyl-label meta-mono">{String(e.extra.no ?? 0).padStart(3, "0")}</div>
                  </div>
                  {/* 封套：生成式封面 */}
                  <div class="sleeve">
                    <Cover id={e.id} module="my-music" cover={e.cover} w={360} h={360} />
                  </div>
                </div>

                <div class="record-meta">
                  <ExhibitLabel
                    no={e.extra.no ?? 0}
                    module="MY MUSIC"
                    year={e.date?.slice(0, 4)}
                    medium={e.tags[0]}
                  />
                  <h2 class="font-display text-2xl">{pickLang(e.title, locale).value}</h2>
                  <p class="text-sm leading-relaxed text-muted">{pickLang(e.summary, locale).value}</p>

                  <div class="record-actions">
                    {playable ? (
                      <button
                        class="play-btn meta-mono"
                        data-play
                        aria-pressed="false"
                        data-label-play={t(locale, "myMusic.play")}
                        data-label-pause={t(locale, "myMusic.pause")}
                      >
                        ▶ {t(locale, "myMusic.play")}
                      </button>
                    ) : null}
                    {e.extra.demo ? (
                      <span class="meta-mono demo-tag">{t(locale, "myMusic.demoTag")}</span>
                    ) : null}
                    {e.links.length ? (
                      <span class="links">
                        <span class="meta-mono">{t(locale, "myMusic.listenOn")}</span>
                        {e.links.map((l) => (
                          <a href={l.url} target="_blank" rel="noopener" class="meta-mono platform">
                            {l.label} ↗
                          </a>
                        ))}
                      </span>
                    ) : (
                      !playable && <span class="meta-mono text-muted">{t(locale, "myMusic.comingSoon")}</span>
                    )}
                  </div>
                  <canvas class="wave" width="280" height="36" aria-hidden="true" />
                </div>
              </div>
            </li>
          );
        })
      }
    </ul>
  </article>
</BaseLayout>

<style>
  .module-head {
    padding-top: clamp(2rem, 8vh, 5rem);
  }
  .room-tag {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
    margin-bottom: 1.2rem;
  }
  .module-title {
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 0.98;
    font-weight: 590;
    margin-left: -0.04em;
  }
  .module-intro {
    margin-top: 1.6rem;
    max-width: 36rem;
    font-size: 1.05rem;
    color: var(--muted);
  }

  .record {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .record-stage {
    position: relative;
    width: min(100%, 340px);
    aspect-ratio: 1;
  }
  .sleeve {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border: 0.5px solid color-mix(in oklab, var(--text) 10%, transparent);
    border-radius: 2px;
    box-shadow: var(--shadow-exhibit);
    background: var(--surface);
    z-index: 2;
  }
  /* 黑胶探出封套一截；hover/播放时滑出更多 */
  .vinyl {
    position: absolute;
    top: 4%;
    right: -14%;
    width: 92%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, #181512 30%, #221e1a 31%, #181512 60%, #25201b 61%, #181512 100%);
    box-shadow: var(--shadow-exhibit);
    z-index: 1;
    transition: right var(--dur-move) var(--ease-gallery);
  }
  .record:hover .vinyl,
  .record.is-playing .vinyl {
    right: -26%;
  }
  .vinyl-grooves {
    position: absolute;
    inset: 7%;
    border-radius: 50%;
    background: repeating-radial-gradient(circle, transparent 0 5px, rgba(255, 255, 255, 0.045) 5px 6px);
  }
  .vinyl-label {
    position: absolute;
    inset: 36%;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(155deg, var(--brass-hi), var(--brass));
    color: #1c1a17;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
  }
  @media (prefers-reduced-motion: no-preference) {
    .record.is-playing .vinyl {
      animation: spin 3.2s linear infinite;
    }
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .record-meta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 30rem;
  }
  .record-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.9rem;
    margin-top: 0.3rem;
  }
  .play-btn {
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--room);
    border-radius: 999px;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    transition: background var(--dur-micro) var(--ease-gallery);
  }
  .play-btn:hover {
    background: color-mix(in oklab, var(--room) 16%, transparent);
  }
  .demo-tag {
    color: color-mix(in oklab, var(--brass) 55%, var(--text));
    border: 1px dashed color-mix(in oklab, var(--brass) 55%, transparent);
    border-radius: 2px;
    padding: 0.15rem 0.45rem;
    font-size: 0.58rem;
  }
  .links {
    display: inline-flex;
    gap: 0.7rem;
    align-items: center;
  }
  .platform {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
  }
  .platform:hover {
    text-decoration: underline;
  }
  .wave {
    width: 280px;
    height: 36px;
    opacity: 0;
    transition: opacity var(--dur-move) var(--ease-gallery);
  }
  .record.is-playing .wave {
    opacity: 1;
  }
</style>

<script>
  /**
   * 录音室播放器：单例 AudioContext + AnalyserNode 音波可视化。
   * 真实音频（data-audio）走 <audio> 元素；demo（data-demo）用内置合成音色——
   * 五声音阶琶音 + 低通滤波，无任何外部资源。同一时间只播一张唱片。
   */
  type Player = { stop: () => void };
  let current: { el: HTMLElement; player: Player } | null = null;
  let actx: AudioContext | null = null;

  function ensureCtx(): AudioContext {
    actx ??= new AudioContext();
    if (actx.state === "suspended") actx.resume();
    return actx;
  }

  function drawWave(analyser: AnalyserNode, canvas: HTMLCanvasElement, room: string) {
    const ctx = canvas.getContext("2d")!;
    const data = new Uint8Array(analyser.frequencyBinCount);
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let raf = 0;
    const frame = () => {
      analyser.getByteFrequencyData(data);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = room;
      const bars = 36;
      const step = Math.floor(data.length / bars);
      for (let i = 0; i < bars; i++) {
        const v = data[i * step] / 255;
        const h = Math.max(2, v * canvas.height);
        ctx.globalAlpha = 0.45 + v * 0.55;
        ctx.fillRect(i * (canvas.width / bars), canvas.height - h, canvas.width / bars - 2, h);
      }
      if (!reduce) raf = requestAnimationFrame(frame);
    };
    frame();
    return () => cancelAnimationFrame(raf);
  }

  function startDemo(card: HTMLElement): Player {
    const ctx = ensureCtx();
    const analyser = ctx.createAnalyser();
    analyser.fftSize = 128;
    const master = ctx.createGain();
    master.gain.value = 0.16;
    const filter = ctx.createBiquadFilter();
    filter.type = "lowpass";
    filter.frequency.value = 1500;
    master.connect(filter).connect(analyser).connect(ctx.destination);

    // 五声音阶琶音（A 宫调式），轻微摇摆
    const scale = [220, 261.63, 293.66, 329.63, 392, 440, 523.25];
    let step = 0;
    const interval = setInterval(() => {
      const f = scale[[0, 2, 4, 6, 5, 3, 1, 2][step % 8]];
      const osc = ctx.createOscillator();
      const g = ctx.createGain();
      osc.type = step % 4 === 0 ? "triangle" : "sine";
      osc.frequency.value = f * (step % 16 < 8 ? 1 : 0.5);
      g.gain.setValueAtTime(0.0001, ctx.currentTime);
      g.gain.exponentialRampToValueAtTime(1, ctx.currentTime + 0.03);
      g.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.55);
      osc.connect(g).connect(master);
      osc.start();
      osc.stop(ctx.currentTime + 0.6);
      step++;
    }, 280);

    const canvas = card.querySelector<HTMLCanvasElement>(".wave")!;
    const room = getComputedStyle(card).getPropertyValue("--room") || "#6b7f95";
    const stopDraw = drawWave(analyser, canvas, `color-mix(in oklab, ${room} 85%, white)`);
    return {
      stop() {
        clearInterval(interval);
        stopDraw();
        master.disconnect();
      },
    };
  }

  function startAudio(card: HTMLElement, url: string): Player {
    const ctx = ensureCtx();
    const el = new Audio(url);
    el.crossOrigin = "anonymous";
    const src = ctx.createMediaElementSource(el);
    const analyser = ctx.createAnalyser();
    analyser.fftSize = 128;
    src.connect(analyser).connect(ctx.destination);
    el.play();
    const canvas = card.querySelector<HTMLCanvasElement>(".wave")!;
    const room = getComputedStyle(card).getPropertyValue("--room") || "#6b7f95";
    const stopDraw = drawWave(analyser, canvas, room);
    return {
      stop() {
        el.pause();
        stopDraw();
        src.disconnect();
      },
    };
  }

  function setBtn(card: HTMLElement, playing: boolean) {
    const btn = card.querySelector<HTMLButtonElement>("[data-play]");
    if (!btn) return;
    btn.setAttribute("aria-pressed", String(playing));
    btn.textContent = playing ? `❚❚ ${btn.dataset.labelPause}` : `▶ ${btn.dataset.labelPlay}`;
  }

  function stopCurrent() {
    if (!current) return;
    current.player.stop();
    current.el.classList.remove("is-playing");
    setBtn(current.el, false);
    current = null;
  }

  document.addEventListener("click", (ev) => {
    const btn = (ev.target as Element).closest<HTMLElement>("[data-play]");
    if (!btn) return;
    const card = btn.closest<HTMLElement>(".record")!;
    if (current?.el === card) {
      stopCurrent();
      return;
    }
    stopCurrent();
    const url = card.dataset.audio;
    const player = url ? startAudio(card, url) : startDemo(card);
    card.classList.add("is-playing");
    setBtn(card, true);
    current = { el: card, player };
  });
  document.addEventListener("astro:before-swap", stopCurrent);
</script>
