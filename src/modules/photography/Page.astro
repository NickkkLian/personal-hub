---
/**
 * Photography（摄影展厅）：冲印相纸墙。
 * - 无 feature 大图：所有作品等大排列，桌面一排两张、移动端单列。
 * - 每张封面统一裁成视频封面比例（16:9），无框画布装裱 + 柔影，hover 射灯微抬。
 * - 每件可有多个原文链接（同一作品被多家转发）；有拍摄地则以 meta-mono 标出。
 * reduced-motion 退化为静态。
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import RoomBand from "../../components/gallery/RoomBand.astro";
import ExhibitFrame from "../../components/gallery/ExhibitFrame.astro";
import ExhibitLabel from "../../components/gallery/ExhibitLabel.astro";
import Cover from "../../components/gallery/Cover.astro";
import { t, pickLang, type Locale } from "../../i18n";
import { MODULE_REGISTRY } from "../../config/site";
import { entries } from "../../lib/data";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const meta = MODULE_REGISTRY.photography;
const shots = entries("photography");
const title = t(locale, "module.photography.title");
---

<BaseLayout
  locale={locale}
  title={title}
  description={t(locale, "module.photography.intro")}
  path={`/${meta.slug}`}
  room={meta.room}
  ghost={t(locale, "module.photography.ghost")}
>
  <article style={`--room: var(${meta.room})`}>
    <header class="module-head enter-rise is-in">
      <p class="meta-mono room-tag">
        {t(locale, "home.roomLabel")}
        {meta.roomNo} — {t(locale, "photography.darkroomTag")}
      </p>
      <h1 class="module-title">{title}</h1>
    </header>

    <RoomBand module="photography" seed="band-photography" caption={t(locale, "module.photography.intro")} />

    <ul class="shots-grid" role="list">
      {
        shots.map((e, i) => {
          const name = pickLang(e.title, locale).value;
          return (
            <li class="shot enter-rise" style={`transition-delay:${Math.min(i * 70, 320)}ms`}>
              <ExhibitFrame variant="canvas" interactive class="shot-frame">
                <figure class="shot-paper">
                  <Cover id={e.id} module="photography" cover={e.cover} alt={name} w={752} h={423} class="shot-img" />
                </figure>
              </ExhibitFrame>
              <div class="shot-cap">
                <ExhibitLabel no={e.extra.no ?? 0} year={e.date?.slice(0, 4)} medium={e.tags[0]} />
                <h3 class="shot-title font-display">{name}</h3>
                <p class="shot-summary">{pickLang(e.summary, locale).value}</p>
                <p class="cap-foot meta-mono">
                  {typeof e.extra.location === "string" && (
                    <span class="loc">{t(locale, "photography.shotAt")} {e.extra.location}</span>
                  )}
                  {e.links.map((l) => (
                    <a href={l.url} target="_blank" rel="noopener noreferrer" class="src">
                      {l.label} ↗
                    </a>
                  ))}
                </p>
              </div>
            </li>
          );
        })
      }
    </ul>
  </article>
</BaseLayout>

<style>
  .module-head {
    padding-top: clamp(1.4rem, 4.5vh, 5rem);
  }
  .room-tag {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
    margin-bottom: 1.2rem;
  }
  .module-title {
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    line-height: 1;
    font-weight: 590;
    margin-left: -0.04em;
  }

  /* —— 相纸网格：桌面两列、移动单列 —— */
  .shots-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.8rem, 4vw, 3rem) clamp(1.2rem, 2.6vw, 2rem);
    margin-top: clamp(1.6rem, 3.5vw, 2.6rem);
  }
  @media (min-width: 720px) {
    .shots-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  .shot {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .shot-paper {
    margin: 0;
    padding: clamp(0.4rem, 1vw, 0.7rem);
    background: var(--surface);
  }
  /* 视频封面比例（16:9），object-fit 兜底任何轻微比例误差 */
  .shot-img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 2px;
  }
  .shot-title {
    font-size: clamp(1.2rem, 2.2vw, 1.55rem);
    line-height: 1.15;
    margin: 0.35rem 0 0.3rem;
  }
  .shot-summary {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--muted);
    max-width: 34rem;
  }

  .cap-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1rem;
    margin-top: 0.6rem;
    font-size: 0.62rem;
  }
  .loc {
    color: color-mix(in oklab, var(--room) 50%, var(--muted));
  }
  .src {
    color: color-mix(in oklab, var(--room) 60%, var(--text));
  }
  .src:hover {
    text-decoration: underline;
  }
</style>
