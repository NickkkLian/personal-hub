---
/**
 * Photography（摄影展厅）：冲印相纸墙 + 视频报道。
 * - 无 feature 大图：所有作品等大排列，桌面一排两张、移动端单列。
 * - 每张封面统一视频封面比例（16:9），无框画布装裱 + 柔影。
 * - 有 extra.video 的作品：封面变可点击 → 站内弹窗播放（HLS：Safari 原生 / 其余 hls.js 动态加载）。
 *   目前 hotlink 点新闻 CDN 流；本地已存 .ts 备份防删，日后可改自托管。
 * - 每件可有多个原文链接；有拍摄地则以 meta-mono 标出。
 * reduced-motion 退化为静态。
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import RoomBand from "../../components/gallery/RoomBand.astro";
import ExhibitFrame from "../../components/gallery/ExhibitFrame.astro";
import ExhibitLabel from "../../components/gallery/ExhibitLabel.astro";
import Cover from "../../components/gallery/Cover.astro";
import { t, pickLang, type Locale } from "../../i18n";
import { MODULE_REGISTRY } from "../../config/site";
import { entries } from "../../lib/data";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const meta = MODULE_REGISTRY.photography;
const shots = entries("photography");
const title = t(locale, "module.photography.title");
---

<BaseLayout
  locale={locale}
  title={title}
  description={t(locale, "module.photography.intro")}
  path={`/${meta.slug}`}
  room={meta.room}
  ghost={t(locale, "module.photography.ghost")}
>
  <article style={`--room: var(${meta.room})`}>
    <header class="module-head enter-rise is-in">
      <p class="meta-mono room-tag">
        {t(locale, "home.roomLabel")}
        {meta.roomNo} — {t(locale, "photography.darkroomTag")}
      </p>
      <h1 class="module-title">{title}</h1>
    </header>

    <RoomBand module="photography" seed="band-photography" caption={t(locale, "module.photography.intro")} />

    <ul class="shots-grid" role="list">
      {
        shots.map((e, i) => {
          const name = pickLang(e.title, locale).value;
          const video = typeof e.extra.video === "string" ? e.extra.video : null;
          return (
            <li class="shot enter-rise" style={`transition-delay:${Math.min(i * 70, 320)}ms`}>
              <ExhibitFrame variant="canvas" interactive class="shot-frame">
                <figure class="shot-paper">
                  {video ? (
                    <button
                      type="button"
                      class="shot-play"
                      data-video={video}
                      data-poster={e.cover}
                      data-label={name}
                      aria-label={`${t(locale, "photography.playVideo")}: ${name}`}
                    >
                      <Cover id={e.id} module="photography" cover={e.cover} alt={name} w={1280} h={719} class="shot-img" />
                      <span class="shot-badge meta-mono" aria-hidden="true">
                        ▶ {t(locale, "photography.videoBadge")}
                      </span>
                    </button>
                  ) : (
                    <Cover id={e.id} module="photography" cover={e.cover} alt={name} w={1280} h={719} class="shot-img" />
                  )}
                </figure>
              </ExhibitFrame>
              <div class="shot-cap">
                <ExhibitLabel no={e.extra.no ?? 0} year={e.date?.slice(0, 4)} medium={e.tags[0]} />
                <h3 class="shot-title font-display">{name}</h3>
                <p class="shot-summary">{pickLang(e.summary, locale).value}</p>
                <p class="cap-foot meta-mono">
                  {typeof e.extra.location === "string" && (
                    <span class="loc">{t(locale, "photography.shotAt")} {e.extra.location}</span>
                  )}
                  {e.links.map((l) => (
                    <a href={l.url} target="_blank" rel="noopener noreferrer" class="src">
                      {l.label} ↗
                    </a>
                  ))}
                </p>
              </div>
            </li>
          );
        })
      }
    </ul>

    <dialog id="video-modal" class="vm" aria-label={t(locale, "photography.playVideo")}>
      <div class="vm-frame">
        <button type="button" class="vm-close" aria-label={t(locale, "photography.closeVideo")}>×</button>
        <video class="vm-video" controls playsinline preload="none"></video>
        <p class="vm-error meta-mono" hidden>{t(locale, "photography.videoUnsupported")}</p>
      </div>
    </dialog>
  </article>
</BaseLayout>

<script>
  /**
   * 站点用 ClientRouter（换页不整页重载）：本脚本只在首次整页加载时执行一次，
   * 元素级监听会随换页的 DOM 替换而丢失 → 一律 document 级委托 + 每次现查 #video-modal。
   * （2026-07-18 实锤：从首页导航进摄影页点封面无反应，直接输网址进来才正常，即此坑。）
   */
  let hls: { destroy: () => void } | null = null;
  const getModal = () => document.getElementById("video-modal") as HTMLDialogElement | null;

  async function play(modal: HTMLDialogElement, src: string, poster: string) {
    const video = modal.querySelector<HTMLVideoElement>(".vm-video")!;
    const errEl = modal.querySelector<HTMLParagraphElement>(".vm-error")!;
    errEl.hidden = true;
    video.poster = poster || "";
    // Safari 等原生支持 HLS：直接喂 m3u8；其余浏览器动态加载 hls.js
    if (video.canPlayType("application/vnd.apple.mpegurl")) {
      video.src = src;
    } else {
      try {
        const { default: Hls } = await import("hls.js");
        if (Hls.isSupported()) {
          const inst = new Hls({ enableWorker: true });
          inst.loadSource(src);
          inst.attachMedia(video);
          inst.on(Hls.Events.ERROR, (_e, data) => {
            if (data.fatal) errEl.hidden = false;
          });
          hls = inst;
        } else {
          video.src = src; // 最后兜底
        }
      } catch {
        errEl.hidden = false;
      }
    }
    if (typeof modal.showModal === "function") modal.showModal();
    video.play().catch(() => {});
  }

  function closeModal(modal: HTMLDialogElement) {
    // 显式清理，不依赖 close 事件（部分环境 dialog.close() 不触发该事件 → 后台续播）
    const video = modal.querySelector<HTMLVideoElement>(".vm-video")!;
    video.pause();
    if (hls) {
      hls.destroy();
      hls = null;
    }
    video.removeAttribute("src");
    video.load();
    if (modal.open) modal.close();
  }

  document.addEventListener("click", (ev) => {
    const modal = getModal();
    if (!modal) return; // 不在摄影页
    const t = ev.target as Element;
    const btn = t.closest<HTMLElement>(".shot-play");
    if (btn) {
      play(modal, btn.dataset.video || "", btn.dataset.poster || "");
      return;
    }
    if (t.closest(".vm-close") || (ev.target === modal && modal.open)) closeModal(modal);
  });
  document.addEventListener("keydown", (ev) => {
    const modal = getModal();
    if (modal?.open && ev.key === "Escape") {
      ev.preventDefault(); // 拦原生关闭，确保先清理（否则视频后台续播）
      closeModal(modal);
    }
  });
  // 换页离开时弹窗若开着，先停播收尾
  document.addEventListener("astro:before-swap", () => {
    const modal = getModal();
    if (modal?.open) closeModal(modal);
  });
</script>

<style>
  .module-head {
    padding-top: clamp(1.4rem, 4.5vh, 5rem);
  }
  .room-tag {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
    margin-bottom: 1.2rem;
  }
  .module-title {
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    line-height: 1;
    font-weight: 590;
    margin-left: -0.04em;
  }

  /* —— 相纸网格：桌面两列、移动单列 —— */
  .shots-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.8rem, 4vw, 3rem) clamp(1.2rem, 2.6vw, 2rem);
    margin-top: clamp(1.6rem, 3.5vw, 2.6rem);
  }
  @media (min-width: 720px) {
    .shots-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  .shot {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .shot-paper {
    margin: 0;
    padding: clamp(0.4rem, 1vw, 0.7rem);
    background: var(--surface);
  }
  /* img 由 Cover 子组件渲染（带子组件 cid）——页面作用域选不中，必须 :global 包裹
     （否则 aspect-ratio 不生效：图未加载时高度 0 → 按钮无可点面积、布局跳动） */
  .shot-paper :global(.shot-img) {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 2px;
  }

  /* —— 可播放封面：整块变按钮 —— */
  .shot-play {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    position: relative;
    border-radius: 2px;
    overflow: hidden;
  }
  .shot-play :global(.shot-img) {
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1), filter 0.4s ease;
  }
  .shot-play::after {
    /* hover 微暗罩，提示可点 */
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 90% at 50% 45%, transparent 40%, rgb(0 0 0 / 0.18));
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .shot-play:hover :global(.shot-img),
  .shot-play:focus-visible :global(.shot-img) {
    transform: scale(1.02);
  }
  .shot-play:hover::after,
  .shot-play:focus-visible::after {
    opacity: 1;
  }
  .shot-play:focus-visible {
    outline: 2px solid var(--room);
    outline-offset: 3px;
  }
  .shot-badge {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.2rem 0.5rem;
    font-size: 0.58rem;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgb(0 0 0 / 0.55);
    border-radius: 999px;
    backdrop-filter: blur(4px);
  }

  .shot-title {
    font-size: clamp(1.2rem, 2.2vw, 1.55rem);
    line-height: 1.15;
    margin: 0.35rem 0 0.3rem;
  }
  .shot-summary {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--muted);
    max-width: 34rem;
  }

  .cap-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1rem;
    margin-top: 0.6rem;
    font-size: 0.62rem;
  }
  .loc {
    color: color-mix(in oklab, var(--room) 50%, var(--muted));
  }
  .src {
    color: color-mix(in oklab, var(--room) 60%, var(--text));
  }
  .src:hover {
    text-decoration: underline;
  }

  /* —— 视频弹窗 —— */
  .vm {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0; /* 显式居中：站点全局 margin 复位会破坏 dialog:modal 的 auto 居中 */
    width: min(92vw, 1100px);
    max-width: 1100px;
    max-height: 92vh;
    padding: 0;
    border: 0;
    background: transparent;
    color: #fff;
    overflow: visible;
  }
  .vm::backdrop {
    background: rgb(0 0 0 / 0.82);
    backdrop-filter: blur(6px);
  }
  .vm-frame {
    position: relative;
  }
  .vm-video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: var(--radius-viewport, 14px);
    box-shadow: 0 24px 70px rgb(0 0 0 / 0.5);
  }
  .vm-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 2;
    width: 2.3rem;
    height: 2.3rem;
    display: grid;
    place-items: center;
    font-size: 1.6rem;
    line-height: 1;
    color: #fff;
    background: rgb(0 0 0 / 0.55);
    border: 1px solid rgb(255 255 255 / 0.35);
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(4px);
  }
  .vm-close:hover {
    background: rgb(0 0 0 / 0.75);
  }
  .vm-error {
    margin-top: 0.8rem;
    text-align: center;
    color: #ffd7d7;
    font-size: 0.75rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .shot-play :global(.shot-img) {
      transition: none;
    }
    .shot-play:hover :global(.shot-img),
    .shot-play:focus-visible :global(.shot-img) {
      transform: none;
    }
  }
</style>
