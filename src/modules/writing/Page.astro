---
/**
 * Writing（详情卡片网格 · 站长要求去掉书架）：
 * 条目直接以"翻开的书"详情卡呈现——封面画 + 标题/摘要/正文节选/日期，按年份分层成网格；
 * 保留 NEW 标记与全站连续展品编号。
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ExhibitFrame from "../../components/gallery/ExhibitFrame.astro";
import Cover from "../../components/gallery/Cover.astro";
import FeatureCard from "../../components/gallery/FeatureCard.astro";
import { t, pickLang, type Locale } from "../../i18n";
import { MODULE_REGISTRY } from "../../config/site";
import { entries, exhibitNo, isNew, pickFeatured } from "../../lib/data";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const meta = MODULE_REGISTRY.writing;
const all = entries("writing");
const featured = pickFeatured("writing", all);
const rest = all.filter((e) => e !== featured);

// 按年份分层（无日期归入最早层底部）
const groups = new Map<string, typeof rest>();
for (const e of rest) {
  const y = e.date?.slice(0, 4) ?? "—";
  if (!groups.has(y)) groups.set(y, []);
  groups.get(y)!.push(e);
}
const years = [...groups.keys()].sort((a, b) => b.localeCompare(a));

const title = t(locale, "module.writing.title");
---

<BaseLayout
  locale={locale}
  title={title}
  description={t(locale, "module.writing.intro")}
  path={`/${meta.slug}`}
  room={meta.room}
  ghost={t(locale, "module.writing.ghost")}
>
  <article style={`--room: var(${meta.room})`}>
    <header class="module-head enter-rise is-in">
      <p class="meta-mono room-tag">
        {t(locale, "home.roomLabel")}
        {meta.roomNo} — {t(locale, "module.writing.ghost")}
      </p>
      <h1 class="module-title">{title}</h1>
      <p class="module-intro">{t(locale, "module.writing.intro")}</p>
    </header>

    {
      featured && (
        <FeatureCard
          locale={locale}
          entry={featured}
          module="writing"
          moduleLabel="WRITING"
          label={t(locale, "common.featured")}
          meta={[featured.extra.sectionLabel, featured.date].filter(Boolean).join(" · ")}
        />
      )
    }

    <hr class="hairline my-10" />

    {
      years.map((y) => (
        <section class="year-group" aria-label={y}>
          <h2 class="meta-mono year-head">
            {y} · {groups.get(y)!.length} {t(locale, "common.works")}
          </h2>
          <ul class="wr-grid">
            {groups.get(y)!.map((e, i) => {
              const tt = pickLang(e.title, locale);
              const sm = pickLang(e.summary, locale).value;
              return (
                <li class="enter-rise" style={`transition-delay:${Math.min(i * 50, 280)}ms`}>
                  <ExhibitFrame interactive class="wr-card">
                    <div class="wr-art">
                      <Cover id={e.id} module="writing" cover={e.cover} w={460} h={300} />
                      {isNew(e) && <span class="wr-new meta-mono">{t(locale, "writing.new")}</span>}
                    </div>
                    <div class="wr-body">
                      <p class="meta-mono wr-no">
                        {exhibitNo(e)} · WRITING
                        {e.extra.sectionLabel ? ` · ${e.extra.sectionLabel}` : ""}
                      </p>
                      <h3 class="font-display wr-title">{tt.value}</h3>
                      {sm && <p class="wr-summary">{sm}</p>}
                      {e.extra.content && <p class="wr-excerpt">{String(e.extra.content).slice(0, 360)}</p>}
                      <p class="wr-foot meta-mono">
                        {tt.fellBack && (
                          <span class="wr-orig">
                            {t(locale, tt.lang === "zh" ? "langTag.originalZh" : "langTag.originalEn")} ·{" "}
                          </span>
                        )}
                        {e.date ?? ""}
                      </p>
                    </div>
                  </ExhibitFrame>
                </li>
              );
            })}
          </ul>
        </section>
      ))
    }
  </article>
</BaseLayout>

<style>
  .module-head {
    padding-top: clamp(2rem, 8vh, 5rem);
  }
  .room-tag {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
    margin-bottom: 1.2rem;
  }
  .module-title {
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 0.98;
    font-weight: 590;
    margin-left: -0.04em;
  }
  .module-intro {
    margin-top: 1.6rem;
    max-width: 36rem;
    font-size: 1.05rem;
    color: var(--muted);
  }

  .year-group {
    margin-bottom: 2.6rem;
  }
  .year-head {
    margin-bottom: 1rem;
  }
  .wr-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.2rem, 2.5vw, 2rem);
  }
  @media (min-width: 640px) {
    .wr-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .wr-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .wr-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }
  .wr-art {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 0.5px solid color-mix(in oklab, var(--text) 8%, transparent);
  }
  .wr-art :global(.cover-art),
  .wr-art :global(.cover-img) {
    transition: transform 1.4s var(--ease-gallery);
  }
  .wr-card:hover .wr-art :global(.cover-art),
  .wr-card:hover .wr-art :global(.cover-img) {
    transform: scale(1.05);
  }
  /* NEW 黄铜书腰 → 角标 */
  .wr-new {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    padding: 0.18rem 0.5rem;
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: #1c1a17;
    background: linear-gradient(155deg, var(--brass-hi), var(--brass));
    border-radius: 2px;
    box-shadow: var(--shadow-plaque);
  }
  .wr-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.1rem 1.2rem 1.3rem;
    flex: 1;
  }
  .wr-no {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
  }
  .wr-title {
    font-size: 1.3rem;
    font-weight: 540;
    line-height: 1.15;
  }
  .wr-summary {
    font-size: 0.92rem;
    color: var(--muted);
  }
  .wr-excerpt {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--text);
    white-space: pre-wrap;
    /* 节选裁到 4 行 */
    display: -webkit-box;
    -webkit-line-clamp: 4;
    line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    opacity: 0.85;
  }
  .wr-foot {
    margin-top: auto;
    padding-top: 0.3rem;
    color: var(--muted);
  }
  .wr-orig {
    color: color-mix(in oklab, var(--room) 50%, var(--muted));
  }
</style>
