---
/**
 * Special Collections（特别馆藏 · 徽章墙）：
 * 每枚徽章像一幅装裱好的画"挂在墙上"（发丝浮框 + 纸白衬底 passe-partout），题注在画下方、直接落在墙面上。
 * 隐私：网页只展示徽章图与信息，证书原件（PDF/扫描件）绝不入库（见 content/special-collections.json）。
 * 交互两态：
 *   - 有验证链接（links[0]）→ 整幅可点，新标签跳官方验证页（rel=noopener noreferrer），题注显示 Verify ↗
 *   - 无验证链接 → 静态徽章，不可跳转，题注显示「在册」
 * 无 feature 卡——以黄铜火漆印章分隔条作装饰，避免单调。
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ExhibitFrame from "../../components/gallery/ExhibitFrame.astro";
import RoomBand from "../../components/gallery/RoomBand.astro";
import ExhibitLabel from "../../components/gallery/ExhibitLabel.astro";
import { t, pickLang, type Locale } from "../../i18n";
import { MODULE_REGISTRY } from "../../config/site";
import { entries } from "../../lib/data";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const meta = MODULE_REGISTRY.special;
const badges = entries("special");
const title = t(locale, "module.special.title");

/** 取徽章图路径（extra.badge）；缺失时回退首字母字母章 */
const initials = (s: string) =>
  s
    .replace(/[^\p{L}\p{N} ]/gu, "")
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0]!.toUpperCase())
    .join("");
---

<BaseLayout
  locale={locale}
  title={title}
  description={t(locale, "module.special.intro")}
  path={`/${meta.slug}`}
  room={meta.room}
  ghost={t(locale, "module.special.ghost")}
>
  <article style={`--room: var(${meta.room})`}>
    <header class="module-head enter-rise is-in">
      <p class="meta-mono room-tag">
        {t(locale, "home.roomLabel")}
        {meta.roomNo} — {t(locale, "special.cabinetTag")}
      </p>
      <h1 class="module-title">{title}</h1>
      <p class="module-intro">{t(locale, "module.special.intro")}</p>
    </header>

    {/* 装饰：流场纹理横幅 + 中央黄铜火漆印章（替代原取景框，画风与各展厅封面统一） */}
    <RoomBand module="special" seed="band-special" seal />

    <ul class="bw-grid" role="list">
      {
        badges.map((e, i) => {
          const name = pickLang(e.title, locale).value;
          const sm = pickLang(e.summary, locale).value;
          const issuer = typeof e.extra.issuer === "string" ? e.extra.issuer : null;
          const badge = typeof e.extra.badge === "string" ? e.extra.badge : null;
          const year = e.extra.year ?? (e.date ? e.date.slice(0, 4) : undefined);
          const verifyUrl = e.links[0]?.url ?? null;
          return (
            <li class="bw-item enter-rise" style={`transition-delay:${Math.min(i * 50, 280)}ms`}>
              {/* 挂在墙上的装裱徽章 */}
              <ExhibitFrame variant="float" class="bw-frame">
                <div class="bw-tile">
                  {badge ? (
                    <img class="bw-badge" src={badge} alt={name} width="200" height="200" loading="lazy" />
                  ) : (
                    <span class="bw-mono font-display" aria-hidden="true">
                      {initials(name)}
                    </span>
                  )}
                  {verifyUrl && (
                    <a
                      class="bw-stretch"
                      href={verifyUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${t(locale, "special.verify")} — ${name}`}
                    />
                  )}
                </div>
              </ExhibitFrame>

              {/* 题注：落在墙面上（画框之外） */}
              <div class="bw-caption">
                <ExhibitLabel
                  no={e.extra.no ?? 0}
                  module="COLLECTIONS"
                  title={name}
                  year={year}
                  medium={issuer ?? undefined}
                />
                {sm && <p class="bw-summary">{sm}</p>}
                {verifyUrl ? (
                  <span class="bw-verify meta-mono">{t(locale, "special.verify")} ↗</span>
                ) : (
                  <span class="bw-onrecord meta-mono">{t(locale, "special.onRecord")}</span>
                )}
              </div>
            </li>
          );
        })
      }
    </ul>
  </article>
</BaseLayout>

<style>
  .module-head {
    padding-top: clamp(2rem, 8vh, 5rem);
  }
  .room-tag {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
    margin-bottom: 1.2rem;
  }
  .module-title {
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    line-height: 1;
    font-weight: 590;
    margin-left: -0.04em;
  }
  .module-intro {
    margin-top: 1.6rem;
    max-width: 36rem;
    font-size: 1.05rem;
    color: var(--muted);
  }

  .bw-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.6rem, 3vw, 2.6rem) clamp(1.2rem, 2.5vw, 2rem);
  }
  @media (min-width: 560px) {
    .bw-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .bw-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1200px) {
    .bw-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .bw-item {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  /* 画框：发丝浮框 + 抬升（挂画感） */
  .bw-frame {
    transition:
      transform var(--dur-move) var(--ease-gallery),
      box-shadow var(--dur-move) var(--ease-gallery);
  }
  .bw-item:hover .bw-frame {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lift);
  }
  .bw-item:focus-within .bw-frame {
    outline: 2px solid color-mix(in oklab, var(--brass) 70%, transparent);
    outline-offset: 3px;
  }
  /* 纸白衬底（两套主题都用纸白，让官方徽标清晰） */
  .bw-tile {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    padding: clamp(0.7rem, 2.2vw, 1.2rem);
    background: var(--paint-canvas);
    border-radius: 1px;
    height: 100%;
  }
  .bw-badge {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 90%;
    filter: drop-shadow(1px 2px 4px rgba(28, 26, 23, 0.16));
    transition: transform var(--dur-move) var(--ease-gallery);
  }
  .bw-item:hover .bw-badge {
    transform: scale(1.03);
  }
  .bw-mono {
    display: grid;
    place-items: center;
    width: clamp(4.5rem, 14vw, 6rem);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--brass) 60%, transparent);
    color: color-mix(in oklab, var(--brass) 70%, var(--text));
    font-size: 1.6rem;
    letter-spacing: 0.04em;
  }
  .bw-stretch {
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  /* 题注：直接落在墙面上 */
  .bw-caption {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0 0.1rem;
  }
  .bw-summary {
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bw-verify {
    padding-top: 0.15rem;
    color: color-mix(in oklab, var(--brass) 62%, var(--text));
    width: max-content;
  }
  .bw-item:hover .bw-verify {
    text-decoration: underline;
  }
  .bw-onrecord {
    padding-top: 0.15rem;
    color: var(--muted);
    opacity: 0.8;
  }
</style>
