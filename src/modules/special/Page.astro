---
/**
 * Special Collections（特别馆藏 · 徽章墙）：
 * 每枚徽章像一幅装裱好的画"挂在墙上"（发丝浮框 + 纸白衬底 passe-partout），题注在画下方、直接落在墙面上。
 * 隐私：网页只展示徽章图与信息，证书原件（PDF/扫描件）绝不入库（见 content/special-collections.json）。
 * 有验证链接（links[0]）→ 整幅徽章可点，新标签跳官方验证页（rel=noopener noreferrer）；无链接 → 静态。
 * 题注：NO 编号 + 标题（破折号后另起一行）+ 年份（首行右对齐）；不显示颁发机构/简介/验证字样。
 * 顶部装饰：流场纹理铭牌横幅（RoomBand，含副标题）。
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ExhibitFrame from "../../components/gallery/ExhibitFrame.astro";
import RoomBand from "../../components/gallery/RoomBand.astro";
import { t, pickLang, type Locale } from "../../i18n";
import { MODULE_REGISTRY } from "../../config/site";
import { entries } from "../../lib/data";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const meta = MODULE_REGISTRY.special;
const badges = entries("special");
const title = t(locale, "module.special.title");

const initials = (s: string) =>
  s
    .replace(/[^\p{L}\p{N} ]/gu, "")
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0]!.toUpperCase())
    .join("");
---

<BaseLayout
  locale={locale}
  title={title}
  description={t(locale, "module.special.intro")}
  path={`/${meta.slug}`}
  room={meta.room}
  ghost={t(locale, "module.special.ghost")}
>
  <article style={`--room: var(${meta.room})`}>
    <header class="module-head enter-rise is-in">
      <p class="meta-mono room-tag">
        {t(locale, "home.roomLabel")}
        {meta.roomNo} — {t(locale, "special.cabinetTag")}
      </p>
      <h1 class="module-title">{title}</h1>
    </header>

    <RoomBand module="special" seed="band-special" caption={t(locale, "module.special.intro")} />

    <ul class="bw-grid" role="list">
      {
        badges.map((e, i) => {
          const name = pickLang(e.title, locale).value;
          const badge = typeof e.extra.badge === "string" ? e.extra.badge : null;
          const year = e.extra.year ?? (e.date ? e.date.slice(0, 4) : undefined);
          const verifyUrl = e.links[0]?.url ?? null;
          // 破折号后的内容另起一行
          const parts = name.split(/\s*—+\s*/);
          const line1 = parts[0];
          const line2 = parts.slice(1).join(" — ");
          const no = String(e.extra.no ?? 0).padStart(3, "0");
          return (
            <li class="bw-item enter-rise" style={`transition-delay:${Math.min(i * 50, 280)}ms`}>
              <ExhibitFrame variant="float" class="bw-frame">
                <div class="bw-tile">
                  {badge ? (
                    <img class="bw-badge" src={badge} alt={name} width="200" height="200" loading="lazy" />
                  ) : (
                    <span class="bw-mono font-display" aria-hidden="true">
                      {initials(name)}
                    </span>
                  )}
                  {verifyUrl && (
                    <a
                      class="bw-stretch"
                      href={verifyUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${t(locale, "special.verify")} — ${name}`}
                    />
                  )}
                </div>
              </ExhibitFrame>

              <div class="bw-caption">
                <p class="bw-no meta-mono">NO. {no}</p>
                <div class="bw-titlerow">
                  <h3 class="bw-title font-display">{line1}</h3>
                  {year && <span class="bw-year meta-mono">{year}</span>}
                </div>
                {line2 && <p class="bw-title2 font-display">{line2}</p>}
              </div>
            </li>
          );
        })
      }
    </ul>
  </article>
</BaseLayout>

<style>
  .module-head {
    padding-top: clamp(2rem, 8vh, 5rem);
  }
  .room-tag {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
    margin-bottom: 1.2rem;
  }
  .module-title {
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    line-height: 1;
    font-weight: 590;
    margin-left: -0.04em;
  }

  .bw-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.4rem, 2.6vw, 2.2rem) clamp(1rem, 2vw, 1.6rem);
  }
  @media (min-width: 480px) {
    .bw-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 720px) {
    .bw-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 980px) {
    .bw-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (min-width: 1240px) {
    .bw-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .bw-item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .bw-frame {
    transition:
      transform var(--dur-move) var(--ease-gallery),
      box-shadow var(--dur-move) var(--ease-gallery);
  }
  .bw-item:hover .bw-frame {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lift);
  }
  .bw-item:focus-within .bw-frame {
    outline: 2px solid color-mix(in oklab, var(--brass) 70%, transparent);
    outline-offset: 3px;
  }
  .bw-tile {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    padding: clamp(0.7rem, 2.2vw, 1.2rem);
    background: var(--paint-canvas);
    border-radius: 1px;
    height: 100%;
  }
  .bw-badge {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 90%;
    filter: drop-shadow(1px 2px 4px rgba(28, 26, 23, 0.16));
    transition: transform var(--dur-move) var(--ease-gallery);
  }
  .bw-item:hover .bw-badge {
    transform: scale(1.03);
  }
  .bw-mono {
    display: grid;
    place-items: center;
    width: clamp(4rem, 12vw, 5.5rem);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--brass) 60%, transparent);
    color: color-mix(in oklab, var(--brass) 70%, var(--text));
    font-size: 1.5rem;
    letter-spacing: 0.04em;
  }
  .bw-stretch {
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  /* 题注：落在墙面上 */
  .bw-caption {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0 0.1rem;
  }
  .bw-no {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
  }
  .bw-titlerow {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .bw-title {
    font-size: 1rem;
    font-weight: 545;
    line-height: 1.14;
  }
  .bw-year {
    flex: 0 0 auto;
    color: var(--muted);
  }
  .bw-title2 {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.14;
    color: var(--muted);
  }
</style>
