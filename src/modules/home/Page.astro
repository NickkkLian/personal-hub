---
/**
 * Home（编辑式门厅 · 对位参考图）：
 * masthead（圆形 logo + GALERIE VIVANTE 刊头）→ 不对称 Hero（左：NO.001/巨型 NICK LIAN./双语题注/展厅数；
 * 右：featured 浮框生成画 + 古典石柱）→ The Rooms 全画幅封面卡（文字只在图下）。
 * 背景纵深由全局 Backdrop（颜料雾 + 色场圆 + 幽灵字）承担。
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ExhibitFrame from "../../components/gallery/ExhibitFrame.astro";
import Cover from "../../components/gallery/Cover.astro";
import ColumnPiece from "../../components/gallery/ColumnPiece.astro";
import Logo from "../../components/Logo.astro";
import { t, localizePath, pickLang, altLocale, type Locale } from "../../i18n";
import { siteConfig, enabledModules } from "../../config/site";
import { entries } from "../../lib/data";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const name = siteConfig.site.title[locale];
const tagline = pickLang(siteConfig.site.tagline, locale);
const taglineAlt = siteConfig.site.tagline[altLocale(locale)];
const rooms = enabledModules().map((m) => {
  const list = entries(m.id);
  return { ...m, count: list.length, coverEntry: list[0] ?? null };
});
const totalOpen = rooms.length;
---

<BaseLayout locale={locale} title={name} description={tagline.value} path="/" ghost={t(locale, "home.ghost")}>
  {/* 刊头 */}
  <header class="masthead enter-rise is-in">
    <Logo variant="stamp" size={46} />
    <span class="meta-mono masthead-kicker">{t(locale, "home.galerie")} · {t(locale, "home.est")}</span>
  </header>

  {/* 编辑式 Hero */}
  <section class="hero-grid">
    {/* 古典石柱：背景元素，置于右侧边缘、内容之后 */}
    <div class="hero-column" aria-hidden="true"><ColumnPiece width={132} /></div>

    <div class="hero-left">
      <p class="meta-mono entrance-no">{t(locale, "home.entranceNo")} · {t(locale, "home.entrance")}</p>
      <h1 class="hero-name">
        <span class="hn-line" data-words>{name.split(" ")[0]}</span>
        <span class="hn-line hn-2" data-words>
          {name.split(" ").slice(1).join(" ") || ""}<span class="title-dot">.</span>
        </span>
      </h1>
      <p class="hero-tagline font-display">
        <span data-words>{tagline.value}</span>
        {taglineAlt && taglineAlt !== tagline.value && <span class="hero-tagline-alt">{taglineAlt}</span>}
      </p>
      <p class="meta-mono rooms-line">
        {t(locale, "home.visitRooms")}
        <span class="rooms-rule"></span>
        {totalOpen}
        {t(locale, "home.open")}
      </p>
    </div>

    <div class="hero-right enter-rise is-in">
      <figure class="featured">
        <ExhibitFrame variant="float">
          <div class="featured-art">
            <Cover id="entrance-featured-000" module="music-wall" w={460} h={560} />
          </div>
        </ExhibitFrame>
        <figcaption class="meta-mono featured-cap">
          NO. 000 · {t(locale, "home.featuredArt")}
        </figcaption>
      </figure>
    </div>
  </section>

  {/* The Rooms：全画幅封面卡，文字只在图下 */}
  <section class="rooms" aria-labelledby="hall-title">
    <div class="rooms-head">
      <h2 id="hall-title">{t(locale, "home.collection")}</h2>
      <p class="meta-mono">{t(locale, "home.hallSubtitle")}</p>
    </div>
    <hr class="hairline mt-5 mb-9" />

    <ul class="rooms-grid">
      {
        rooms.map((m, i) => (
          <li class="enter-rise" style={`transition-delay:${Math.min(i * 60, 300)}ms`}>
            <a
              href={localizePath(locale, `/${m.slug}`)}
              class="rc"
              data-mod={m.id}
              style={`--room: var(${m.room})`}
            >
              <div class="rc-art">
                {m.coverEntry ? (
                  <Cover id={m.coverEntry.id} module={m.id} cover={m.coverEntry.cover} w={420} h={340} />
                ) : (
                  <div class="rc-blank" />
                )}
                <span class="card-sweep" aria-hidden="true" />
              </div>
              <div class="rc-label">
                <span class="meta-mono rc-no">
                  {t(locale, "home.roomLabel").toUpperCase()} {m.roomNo} ·{" "}
                  {m.id.toUpperCase().replace("-", " ")}
                  {m.count > 0 && (
                    <span class="rc-count">
                      {" "}
                      · {m.count} {t(locale, "common.works")}
                    </span>
                  )}
                </span>
                <span class="rc-title font-display">{t(locale, `nav.${m.id}`)}</span>
                <span class="rc-intro">{t(locale, `module.${m.id}.intro`)}</span>
                <span class="meta-mono rc-enter">{t(locale, "home.enter")} →</span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .masthead {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: clamp(0.5rem, 3vh, 2rem);
    flex-wrap: wrap;
  }
  .masthead-kicker {
    letter-spacing: 0.16em;
  }

  /* 不对称 Hero */
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: clamp(2rem, 7vh, 5rem);
    padding-bottom: clamp(2rem, 6vh, 4rem);
  }
  /* 古典石柱：背景配角，右侧边缘、内容之后、出血到顶 */
  .hero-column {
    position: absolute;
    right: clamp(-2rem, 2vw, 3rem);
    top: -3.5rem;
    z-index: 0;
    opacity: 0.5;
    pointer-events: none;
  }
  .hero-left,
  .hero-right {
    position: relative;
    z-index: 1;
  }
  @media (max-width: 700px) {
    .hero-column {
      display: none;
    }
  }
  @media (min-width: 880px) {
    .hero-grid {
      grid-template-columns: 1.45fr 1fr;
      align-items: start;
    }
  }
  .entrance-no {
    color: color-mix(in oklab, var(--brass) 60%, var(--text));
    margin-bottom: 1.4rem;
  }
  /* 巨型标题：Playfair Display（高对比 Didone，对位参考图），两行错开 */
  .hero-name {
    font-family: "Playfair Display Variable", Georgia, serif;
    font-variation-settings: normal;
    font-size: clamp(3.8rem, 13vw, 9.5rem);
    line-height: 0.9;
    font-weight: 680;
    letter-spacing: -0.005em;
    text-transform: uppercase;
  }
  .hn-line {
    display: block;
  }
  .hn-2 {
    margin-left: clamp(1.2rem, 6vw, 4.5rem); /* 第二行右移错开 */
  }
  .title-dot {
    color: var(--brass);
  }
  .hero-tagline {
    margin-top: 1.6rem;
    max-width: 30rem;
    font-size: clamp(1.15rem, 2.3vw, 1.6rem);
    font-style: italic;
    font-weight: 440;
    color: var(--muted);
    text-wrap: balance;
  }
  .hero-tagline-alt {
    display: block;
    margin-top: 0.3rem;
  }
  .rooms-line {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 2rem;
    color: var(--muted);
  }
  .rooms-rule {
    flex: 0 0 auto;
    width: clamp(2rem, 8vw, 6rem);
    height: 1px;
    background: var(--line-hair);
  }

  /* 右侧：石柱 + featured 浮框 */
  .hero-right {
    position: relative;
    display: flex;
    justify-content: flex-end;
  }
  .hero-column {
    position: absolute;
    right: -0.5rem;
    top: 2.2rem;
    z-index: 0;
    opacity: 0.8;
  }
  .featured {
    position: relative;
    z-index: 1;
    width: min(100%, 360px);
    margin: 0;
  }
  .featured-art {
    aspect-ratio: 23 / 28;
    overflow: hidden;
  }
  .featured-cap {
    margin-top: 0.7rem;
    color: var(--muted);
  }

  /* The Rooms：全画幅封面卡 */
  .rooms {
    margin-top: clamp(2rem, 5vh, 4rem);
  }
  .rooms-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .rooms-head h2 {
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .rooms-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2.5vw, 2rem);
  }
  @media (min-width: 760px) {
    .rooms-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .rc {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .rc-art {
    position: relative;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    border: 0.5px solid color-mix(in oklab, var(--text) 10%, transparent);
    border-radius: var(--radius-frame);
    box-shadow: var(--shadow-exhibit);
    transition:
      transform var(--dur-move) var(--ease-gallery),
      box-shadow var(--dur-move) var(--ease-gallery);
  }
  .rc:hover .rc-art {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lift);
  }
  .rc-art :global(.cover-art),
  .rc-art :global(.cover-img) {
    transition: transform 1.4s var(--ease-gallery);
  }
  .rc:hover .rc-art :global(.cover-art),
  .rc:hover .rc-art :global(.cover-img) {
    transform: scale(1.06);
  }
  .rc-blank {
    width: 100%;
    height: 100%;
    background: var(--surface-2);
  }
  .card-sweep {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 30%,
      color-mix(in oklab, var(--brass-hi) 38%, transparent) 48%,
      transparent 66%
    );
    transform: translateX(-120%);
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .rc:hover .card-sweep {
      animation: sweep 0.9s var(--ease-gallery);
    }
  }
  @keyframes sweep {
    0% {
      transform: translateX(-120%);
      opacity: 0;
    }
    40% {
      opacity: 1;
    }
    100% {
      transform: translateX(120%);
      opacity: 0;
    }
  }

  /* 文字只在图下方 */
  .rc-label {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 0.8rem;
  }
  .rc-no {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
  }
  .rc-count {
    color: var(--muted);
  }
  .rc-title {
    font-size: 1.35rem;
    font-weight: 540;
  }
  .rc-intro {
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--muted);
  }
  .rc-enter {
    color: var(--muted);
    margin-top: 0.2rem;
    transition: color var(--dur-micro) var(--ease-gallery);
  }
  .rc:hover .rc-enter {
    color: color-mix(in oklab, var(--room) 55%, var(--text));
  }

  /* 首屏文字逐词浮现 */
  @media (prefers-reduced-motion: no-preference) {
    [data-words] :global(.w) {
      display: inline-block;
      opacity: 0;
      transform: translateY(0.5em);
      animation: word-rise var(--dur-enter) var(--ease-gallery) forwards;
      animation-delay: var(--d, 0ms);
    }
  }
  @keyframes word-rise {
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // 首屏文字逐词浮现
  function splitWords() {
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    document.querySelectorAll<HTMLElement>("[data-words]:not([data-split])").forEach((el) => {
      el.setAttribute("data-split", "");
      const words = (el.textContent ?? "").split(/(\s+)/);
      el.textContent = "";
      let i = 0;
      for (const w of words) {
        if (/^\s+$/.test(w)) {
          el.append(w);
          continue;
        }
        const span = document.createElement("span");
        span.className = "w";
        span.style.setProperty("--d", `${120 + i * 90}ms`);
        span.textContent = w;
        el.append(span);
        i++;
      }
    });
  }
  splitWords();
  document.addEventListener("astro:after-swap", splitWords);
</script>
