---
import BaseLayout from "../layouts/BaseLayout.astro";
import BrassPlaque from "../components/gallery/BrassPlaque.astro";
import { t } from "../i18n";
---

<BaseLayout locale="en" title="404" description={t("en", "notFound.body")} path="/404" ghost="404">
  <section class="flex min-h-[55vh] flex-col items-start justify-center gap-5">
    <BrassPlaque text="ROOM 404" />
    <h1 class="text-5xl sm:text-6xl">{t("en", "notFound.title")}</h1>
    <p class="max-w-md text-muted">{t("en", "notFound.body")}</p>
    <p class="max-w-md text-muted" lang="zh-CN">{t("zh", "notFound.body")}</p>
    <div class="mt-4 flex gap-6">
      <a href="/" class="meta-mono underline underline-offset-4 hover:text-text"
        >← {t("en", "notFound.back")}</a
      >
      <a href="/zh" class="meta-mono underline underline-offset-4 hover:text-text" lang="zh-CN"
        >← {t("zh", "notFound.back")}</a
      >
    </div>
  </section>
</BaseLayout>
