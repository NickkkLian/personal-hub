---
import { ClientRouter } from "astro:transitions";
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import "@fontsource-variable/manrope";
// 可选字体（admin 可在 site.config.fonts 切换）：@font-face 声明常驻，
// woff2 仅在被实际选用时下载，故不增加默认页面字体负担。
import "@fontsource/space-mono";
import "@fontsource-variable/playfair-display";
import "@fontsource-variable/cormorant";
import "@fontsource/ibm-plex-mono";
import "../styles/global.css";
import { t, type Locale } from "../i18n";
import { siteConfig, fontStacks } from "../config/site";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Backdrop from "../components/gallery/Backdrop.astro";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** 不带语言前缀的页面路径（用于 hreflang 双语互链），如 "/writing" */
  path: string;
  /** 模块房间色变量名，如 "--room-writing" */
  room?: string;
  /** 背景幽灵字 */
  ghost?: string;
}
const { locale, title, description, path, room, ghost } = Astro.props;

const siteUrl = (Astro.site ?? new URL(siteConfig.site.url)).href.replace(/\/$/, "");
const cleanPath = path === "/" ? "" : path;
// 目录式尾斜杠与 sitemap 输出保持一致，避免 canonical 分裂
const enHref = cleanPath ? `${siteUrl}${cleanPath}/` : `${siteUrl}/`;
const zhHref = cleanPath ? `${siteUrl}/zh${cleanPath}/` : `${siteUrl}/zh/`;
const canonical = locale === "zh" ? zhHref : enHref;
const fullTitle =
  path === "/" ? title : `${title} · ${t(locale, "home.heroKicker")} — ${siteConfig.site.title[locale]}`;
const ogImage = `${siteUrl}/og.png`;
const umamiId = siteConfig.site.umamiWebsiteId;
const fonts = fontStacks();
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.site.title.en,
    url: `${siteUrl}/`,
    inLanguage: ["en", "zh-CN"],
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: siteConfig.site.title.en,
    url: `${siteUrl}/`,
    email: `mailto:${siteConfig.site.email}`,
    sameAs: siteConfig.site.socials.map((s) => s.url),
  },
];
---

<!doctype html>
<html
  lang={locale === "zh" ? "zh-CN" : "en"}
  data-theme="light"
  style={`--font-display: ${fonts.display}; --font-mono: ${fonts.mono}`}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="zh-CN" href={zhHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteConfig.site.title[locale]} — Writing`}
      href={locale === "zh" ? "/zh/rss.xml" : "/rss.xml"}
    />
    <meta name="color-scheme" content="light dark" />

    <!-- OpenGraph / Twitter Card -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.site.title.en} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale === "zh" ? "zh_CN" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "zh" ? "en_US" : "zh_CN"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- 结构化数据（Person / WebSite） -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <!-- Umami 统计（无 Cookie；site.config 填入 umamiWebsiteId 后生效） -->
    {umamiId && <script defer src="https://cloud.umami.is/script.js" data-website-id={umamiId} is:inline />}

    <!-- 主题无闪烁：首帧前按 localStorage → 系统偏好 设定，View Transitions 换页后重设 -->
    <script is:inline>
      (() => {
        const apply = () => {
          const saved = localStorage.getItem("hub-theme");
          const theme =
            saved === "dark" || saved === "light"
              ? saved
              : matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.dataset.theme = theme;
        };
        apply();
        document.addEventListener("astro:after-swap", apply);
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link meta-mono">{t(locale, "a11y.skipToContent")}</a>
    <Backdrop room={room} ghost={ghost} />
    <Nav locale={locale} />
    <main id="main" class="relative z-10 mx-auto w-full max-w-6xl px-5 pt-24 pb-20 sm:px-8">
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- 入场动画触发器：滚动入视口时点亮 .enter-rise -->
    <script>
      function wireEnterRise() {
        const els = document.querySelectorAll(".enter-rise:not(.is-in)");
        if (!("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      }
      wireEnterRise();
      document.addEventListener("astro:after-swap", wireEnterRise);
    </script>
  </body>
</html>
